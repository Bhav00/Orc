# Copy this file to .env and fill in your values.

# Path to profiles.yaml (default: profiles.yaml in the working directory)
ORCHESTRATOR_PROFILES_PATH=profiles.yaml

# Full path to llama-server.exe
ORCHESTRATOR_LLAMA_SERVER_BIN=C:/llama.cpp/llama-server.exe

# Internal port the child llama-server listens on (not exposed externally)
ORCHESTRATOR_CHILD_PORT=8090

# Where the orchestrator itself listens
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8080

# Total VRAM on the card in MB (used for pre-spawn sanity check)
ORCHESTRATOR_VRAM_TOTAL_MB=32000

# VRAM headroom to keep free (model must fit within total - reserve)
ORCHESTRATOR_VRAM_RESERVE_MB=2000

# How long to wait for llama-server to become healthy after spawn (seconds)
ORCHESTRATOR_SPAWN_TIMEOUT_SECONDS=60

# How long to sleep after killing the child before spawning a new one (seconds)
# Gives Windows time to release VRAM before the next model loads
ORCHESTRATOR_POST_KILL_DELAY_SECONDS=2.0

# Kill idle child after this many seconds of no requests (0 = disabled)
ORCHESTRATOR_IDLE_TTL_SECONDS=600

# Required header value for /admin/* routes (leave blank to disable admin routes)
ORCHESTRATOR_ADMIN_KEY=

# Health poll interval for remote backends in seconds (0 = disabled)
ORCHESTRATOR_BACKEND_HEALTH_INTERVAL=30

# CORS — comma-separated allowed origins, or "*" for all (empty = disabled)
# Example: http://localhost:3000,http://localhost:8501
ORCHESTRATOR_CORS_ORIGINS=

# Model ID to pre-load into VRAM on startup (empty = no preload)
ORCHESTRATOR_PRELOAD_MODEL=

# Directory for rolling log files (orc.log, requests.jsonl, metrics.json, metrics.db)
ORCHESTRATOR_LOG_DIR=logs

# How often (seconds) to save the in-memory metrics snapshot to logs/metrics.json
# The snapshot is loaded on restart to restore aggregate counters.  0 = disabled.
ORCHESTRATOR_METRICS_SNAPSHOT_INTERVAL=60

# Request queuing during model swap
# Max seconds a request will wait for a model swap before returning 503 + Retry-After.
# 0 = wait indefinitely (no timeout).
ORCHESTRATOR_SWAP_TIMEOUT_SECONDS=30
# Max number of requests allowed to queue for a model swap at once.
# Requests beyond this limit are rejected immediately with 503 + Retry-After.
# 0 = unlimited.
ORCHESTRATOR_SWAP_QUEUE_DEPTH=0

# Repetition detection — detects repeated token loops in LLM output.
# Sliding window size in characters (0 = disabled).
ORCHESTRATOR_REPEAT_DETECTION_WINDOW=0
# How many times a pattern must repeat consecutively to trigger.
ORCHESTRATOR_REPEAT_DETECTION_THRESHOLD=4
# Action: "abort" = inject error SSE and stop; "warn" = log only.
ORCHESTRATOR_REPEAT_DETECTION_ACTION=abort
